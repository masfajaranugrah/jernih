# ==============================================================
# Eccomarket Backend — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ==============================================================

# Server
PORT=3001

NODE_ENV=development

# PostgreSQL — ganti sesuai konfigurasi database kamu
DATABASE_URL="postgresql://user:password@localhost:5432/eccomerce"

# JWT
JWT_SECRET=ganti_dengan_secret_yang_panjang_dan_acak
JWT_EXPIRES_IN=7d

# CORS — origin yang diizinkan (Next.js frontend)
CORS_ORIGIN=http://localhost:3000

# Mitra resmi yang dipakai untuk semua produk dari admin dashboard
# Isi dengan ID mitra "Jernih Creatife Official Store" dari tabel mitras
ADMIN_MITRA_ID=isi_dengan_mitra_id_dari_database
