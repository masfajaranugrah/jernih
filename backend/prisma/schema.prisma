// prisma/schema.prisma
// Eccomarket — PostgreSQL schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  MITRA
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum RentalStatus {
  PENDING
  ACTIVE
  RETURNED
  CANCELLED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VoucherType {
  PERCENTAGE
  FIXED
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatar    String?
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mitra       Mitra?
  addresses   Address[]
  orders      Order[]
  rentals     Rental[]
  wishlist    Wishlist[]
  chatsSent   Chat[]        @relation("SentMessages")
  chatsRecv   Chat[]        @relation("ReceivedMessages")
  complaints  Complaint[]
  voucherUses VoucherUse[]

  @@map("users")
}

// ─── Mitra (seller/service provider) ─────────────────────────────────────────

model Mitra {
  id            String   @id @default(cuid())
  userId        String   @unique
  storeName     String
  description   String?
  logo          String?
  banner        String?
  address       String?
  city          String?
  province      String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  rating        Float    @default(0)
  totalReviews  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  services   Service[]
  rentals    Rental[]
  complaints Complaint[]

  @@map("mitras")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  products Product[]
  services Service[]

  @@map("categories")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  categoryId  String?
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(12, 2)
  oldPrice    Decimal? @db.Decimal(12, 2)
  stock       Int      @default(0)
  images      String[] // array URL gambar
  isActive    Boolean  @default(true)
  rating      Float    @default(0)
  totalSold   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  category   Category?  @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  wishlist   Wishlist[]

  @@map("products")
}

// ─── Service (Jasa) ───────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  mitraId     String?
  categoryId  String?
  name        String
  slug        String   @unique
  description String?
  priceFrom   Decimal  @db.Decimal(12, 2)
  unit        String   @default("project") // project, m2, jam, dll
  images      String[]
  isActive    Boolean  @default(true)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  mitra      Mitra?     @relation(fields: [mitraId], references: [id], onDelete: SetNull)
  category   Category?  @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("services")
}

// ─── Rental Item ──────────────────────────────────────────────────────────────

model RentalItem {
  id          String   @id @default(cuid())
  mitraId     String?
  name        String
  slug        String   @unique
  description String?
  pricePerDay Decimal  @db.Decimal(12, 2)
  deposit     Decimal? @db.Decimal(12, 2)
  images      String[]
  isActive    Boolean  @default(true)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rentals Rental[]

  @@map("rental_items")
}

// ─── Rental (Sewa) ────────────────────────────────────────────────────────────

model Rental {
  id           String       @id @default(cuid())
  userId       String
  mitraId      String
  rentalItemId String
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  totalPrice   Decimal      @db.Decimal(12, 2)
  status       RentalStatus @default(PENDING)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  user       User       @relation(fields: [userId], references: [id])
  mitra      Mitra      @relation(fields: [mitraId], references: [id])
  rentalItem RentalItem @relation(fields: [rentalItemId], references: [id])

  @@map("rentals")
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  addressId       String?
  voucherUseId    String?     @unique
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(12, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  notes           String?
  paymentMethod   String?
  paymentProof    String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id])
  address    Address?    @relation(fields: [addressId], references: [id])
  items      OrderItem[]
  voucherUse VoucherUse? @relation(fields: [voucherUseId], references: [id])
  complaint  Complaint?

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  serviceId String?
  name      String  // snapshot nama produk/jasa saat order
  price     Decimal @db.Decimal(12, 2)
  quantity  Int     @default(1)
  subtotal  Decimal @db.Decimal(12, 2)

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])

  @@map("order_items")
}

// ─── Address ──────────────────────────────────────────────────────────────────

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String   @default("Rumah") // Rumah, Kantor, dll
  recipient  String
  phone      String
  street     String
  city       String
  province   String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─── Voucher ──────────────────────────────────────────────────────────────────

model Voucher {
  id             String      @id @default(cuid())
  code           String      @unique
  description    String?
  type           VoucherType @default(PERCENTAGE)
  value          Decimal     @db.Decimal(10, 2) // persen atau nominal
  minPurchase    Decimal     @default(0) @db.Decimal(12, 2)
  maxDiscount    Decimal?    @db.Decimal(12, 2) // max potongan untuk tipe PERCENTAGE
  quota          Int         @default(100)
  usedCount      Int         @default(0)
  isActive       Boolean     @default(true)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  uses VoucherUse[]

  @@map("vouchers")
}

model VoucherUse {
  id         String   @id @default(cuid())
  voucherId  String
  userId     String
  usedAt     DateTime @default(now())

  // Relations
  voucher Voucher @relation(fields: [voucherId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  order   Order?

  @@unique([voucherId, userId]) // 1 voucher per user
  @@map("voucher_uses")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Chat {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  imageUrl   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("chats")
}

// ─── Complaint ────────────────────────────────────────────────────────────────

model Complaint {
  id          String          @id @default(cuid())
  userId      String
  mitraId     String?
  orderId     String?         @unique
  title       String
  description String
  images      String[]
  status      ComplaintStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  user  User   @relation(fields: [userId], references: [id])
  mitra Mitra? @relation(fields: [mitraId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("complaints")
}

// ─── Hero Banner ──────────────────────────────────────────────────────────────

model HeroBanner {
  id           String   @id @default(cuid())
  position     Int      @unique // 0=main, 1=top-right, 2=bottom-left, 3=bottom-right
  badge        String?
  title        String
  titleSuffix  String?
  subtitle     String?
  tagline      String?
  description  String?
  ctaText      String?
  ctaColor     String?
  ctaTextColor String?
  bgColor      String   @default("#064e3b")
  imageUrl     String?
  imageAlt     String?
  linkHref     String?
  align        String   @default("left")
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  @@map("hero_banners")
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
